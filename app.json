{
  "name": "Zaelix",
  "description": "A WhatsApp bot built with Go and whatsmeow",
  "keywords": [
    "go",
    "whatsapp",
    "bot"
  ],
  "repository": "https://github.com/ayzalee/deploy-zaelix",
  "stack": "container",
  "env": {
    "BOT_PREFIX": {
      "description": "Command prefix for the bot",
      "required": false,
      "value": "."
    },
    "SUDO": {
      "description": "Your phone number, international format, no +",
      "required": false,
      "value": ""
    },
    "BOT_NUMBER": {
      "description": "Phone number to pair the bot with (international format, no +) \u2014 required for first deploy since there is no CLI access for --phone-number",
      "required": false,
      "value": ""
    },
    "BOT_MODE": {
      "description": "public or private",
      "required": false,
      "value": "public"
    },
    "BOT_LANG": {
      "description": "Bot language",
      "required": false,
      "value": "en"
    },
    "ALWAYS_ONLINE": {
      "description": "Show bot number last seen as online",
      "required": false,
      "value": "false"
    },
    "AUTO_STATUS_VIEW": {
      "description": "View others' status automatically",
      "required": false,
      "value": "false"
    },
    "CALL_REJECT": {
      "description": "Auto reject calls, if set as true",
      "required": false,
      "value": "false"
    },
    "READ_MSGS": {
      "description": "Send blue tick (auto read messages)",
      "required": false,
      "value": "false"
    },
    "ANTI_DELETE": {
      "description": "Forward deleted messages instead of letting them disappear",
      "required": false,
      "value": "false"
    },
    "STATUS_VIEW_EMOJI": {
      "description": "Emojis used to react to viewed statuses",
      "required": false,
      "value": "\u2764\ufe0f,\ud83e\udebb,\ud83e\udd0d,\ud83c\udf90,\ud83c\udf38,\ud83d\udcab"
    },
    "YT_COOKIE": {
      "description": "YouTube cookie string for yt-dlp (optional)",
      "required": false,
      "value": ""
    },
    "TZ": {
      "description": "Timezone for menu/uptime display",
      "required": false,
      "value": "UTC"
    },
    "HEROKU_APP_NAME": {
      "description": "Heroku app name, same as entered above (for self-restart support)",
      "required": false,
      "value": ""
    },
    "HEROKU_API_KEY": {
      "description": "Heroku account API key, https://dashboard.heroku.com/account (for self-restart support)",
      "required": false,
      "value": ""
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0"
    }
  ],
  "buildpacks": [],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
}